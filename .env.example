# ==============================================================================
# Application
# ==============================================================================
NODE_ENV=development
PORT=3000

# ==============================================================================
# Database (PostgreSQL)
# ==============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=game_music

# When running via docker-compose, set DB_HOST=postgres (the service name).

# ==============================================================================
# Auth (JWT)
# ==============================================================================
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d
