# ==============================================================================
# Application
# ==============================================================================
NODE_ENV=development
PORT=3000

# ==============================================================================
# Database (PostgreSQL)
# ==============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=game_music
DB_SCHEMA=public

# Connection string used by TypeORM / the app.
# When running via docker-compose, set DB_HOST=postgres (the service name).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/game_music?schema=public

# ==============================================================================
# Auth (JWT)
# ==============================================================================
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d
